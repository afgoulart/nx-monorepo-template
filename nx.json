{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "production": [
      "default"
    ],
    "sharedGlobals": []
  },
  "targetDefaults": {
    "build": {
      "dependsOn": [
        "^build"
      ]
    },
    "test": {
      "dependsOn": [
        "^build"
      ]
    }
  },
  "plugins": [
    {
      "plugin": "@nx-dotnet/core",
      "options": {
        "moduleBoundaries": [
          {
            "sourceTag": "scope:workflow-a",
            "onlyDependOnLibsWithTags": ["scope:workflow-a", "scope:shared"]
          },
          {
            "sourceTag": "scope:workflow-b",
            "onlyDependOnLibsWithTags": ["scope:workflow-b", "scope:shared"]
          },
          {
            "sourceTag": "scope:shared",
            "onlyDependOnLibsWithTags": ["scope:shared"]
          },
          {
            "sourceTag": "type:app",
            "onlyDependOnLibsWithTags": ["type:lib"]
          },
          {
            "sourceTag": "type:lib",
            "onlyDependOnLibsWithTags": ["type:lib"]
          },
          {
            "sourceTag": "type:test",
            "onlyDependOnLibsWithTags": ["type:lib", "type:app", "type:test"]
          }
        ]
      }
    }
  ]
}
